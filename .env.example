# ===========================================================================
# NGC AI Exchange – Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (defaults to SQLite in app/backend/hedge_fund.db)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite:///app/backend/hedge_fund.db
# For PostgreSQL (local):
# DATABASE_URL=postgresql://user:password@localhost:5432/ngc_exchange
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres.<user>:<password>@db.<project>.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# CORS – extra allowed origins (comma-separated, in addition to built-in list)
# Built-in: localhost:5173, localhost:3000, smartkonnect.co.uk
# ---------------------------------------------------------------------------
# CORS_EXTRA_ORIGINS=https://custom-domain.com,https://staging.smartkonnect.co.uk

# ---------------------------------------------------------------------------
# API authentication & docs exposure
# ---------------------------------------------------------------------------
# ADMIN_API_KEYS=sha256:<hash>,sha256:<hash>
#   • Generate hashes via:
#       python3 - <<'PY'
#       import hashlib; print('sha256:' + hashlib.sha256(b'your-key-here').hexdigest())
#       PY
# API_KEY_ENCRYPTION_KEY=base64-generated-fernet-key (required in production)
# ENABLE_API_DOCS=false

# ---------------------------------------------------------------------------
# Rate limiting (SlowAPI middleware)
# ---------------------------------------------------------------------------
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_BURST_PER_SECOND=10

# ---------------------------------------------------------------------------
# Frontend API URL (used by Vite build – set in your hosting env or .env)
# ---------------------------------------------------------------------------
# VITE_API_URL=https://api.smartkonnect.co.uk

# ---------------------------------------------------------------------------
# Financial Data API
# ---------------------------------------------------------------------------
# Get your Financial Datasets API key from https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# ---------------------------------------------------------------------------
# LLM Provider API Keys (set only the providers you plan to use)
# ---------------------------------------------------------------------------

# OpenAI (GPT-4, GPT-4o, etc.)
# https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key
# Optional: custom base URL for OpenAI-compatible providers
# OPENAI_API_BASE=

# Anthropic (Claude 3.5, Claude 4, etc.)
# https://anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# DeepSeek
# https://deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# Groq (fast inference for open-source models)
# https://groq.com/
GROQ_API_KEY=your-groq-api-key

# Google Gemini
# https://ai.dev/
GOOGLE_API_KEY=your-google-api-key

# xAI (Grok)
XAI_API_KEY=your-xai-api-key

# GigaChat
GIGACHAT_API_KEY=your-gigachat-api-key

# OpenRouter (multi-provider gateway)
OPENROUTER_API_KEY=your-openrouter-api-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# ---------------------------------------------------------------------------
# Ollama (local LLM – no API key needed)
# ---------------------------------------------------------------------------
# OLLAMA_HOST=localhost
# OLLAMA_BASE_URL=http://localhost:11434
